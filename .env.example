# Database
DATABASE_URL=postgresql://user:password@localhost/wildfire_db

# NASA FIRMS API
NASA_FIRMS_API_KEY=your_nasa_firms_key_here

# Google Earth Engine
GOOGLE_EARTH_ENGINE_SERVICE_ACCOUNT=your-account@project.iam.gserviceaccount.com
GOOGLE_EARTH_ENGINE_PRIVATE_KEY_PATH=/path/to/private-key.json

# OpenWeatherMap (optional backup)
OPENWEATHER_API_KEY=your_openweather_key_here
